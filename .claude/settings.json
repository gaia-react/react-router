{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-session-stop.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/wiki-squash-autocommits.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/intercept-init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-eslint-config-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-vitest-globals-tsconfig.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-i18n-strings.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-story-exists.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-bare-npm-test.sh",
            "if": "Bash(npm *)"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-main-destructive-git.sh",
            "if": "Bash(git *)",
            "statusMessage": "Checking main-branch protection…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pr-merge-audit-check.sh",
            "if": "Bash(gh pr merge:*)",
            "statusMessage": "Checking PR-merge audit gate…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/wiki-maintenance-check.sh",
            "if": "Bash(git commit:*)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p .claude/plans)",
      "Bash(mkdir -p .claude/handoff/archive)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm run lint)",
      "Bash(npm run pw:*)",
      "Bash(npm run test:ci:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm uninstall:*)",
      "Write(.claude/plans/**)",
      "Edit(.claude/plans/**)",
      "Edit(/app/**)",
      "Edit(/public/**)",
      "Edit(/test/**)",
      "Edit(/.playwright/**)",
      "Edit(/.storybook/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/secrets/*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
