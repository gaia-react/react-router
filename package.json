{
  "name": "gaia-template-react-router",
  "version": "1.0.0-beta",
  "description": "Gaia Template for React Router",
  "author": "Steven Sacks <stevensacks@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepare": "is-ci || husky && npx playwright install --with-deps",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "npx eslint --fix --max-warnings=0 --ext js,jsx,ts,tsx app --cache --cache-location ./node_modules/.cache/eslint .",
    "lint-dry": "npx eslint --fix-dry-run --max-warnings=0 --ext js,jsx,ts,tsx app --cache --cache-location ./node_modules/.cache/eslint .",
    "lint-all": "npm run typecheck && npm run lint && npm run format && npm run stylelint",
    "format": "prettier --ignore-path .prettierignore --write \"**/*.{ts,tsx,html,md,mdx,css,json}\"",
    "stylelint": "stylelint --fix app/**/*.css",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:ci": "vitest --run --passWithNoTests --coverage --bail 1",
    "test:lint-staged": "vitest --run --changed --passWithNoTests --bail 1",
    "pw": "npx playwright test",
    "pw-ui": "npx playwright test --ui",
    "chromatic": "npx chromatic --auto-accept-changes 'main' --storybook-build-dir 'storybook-static' --only-changed --exit-once-uploaded --exit-zero-on-changes --skip '@(renovate/**|dependabot/**)'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --test"
  },
  "dependencies": {
    "@conform-to/react": "^1.19.0",
    "@conform-to/zod": "^1.19.0",
    "@epic-web/invariant": "1.0.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@react-router/node": "^7.14.1",
    "@react-router/remix-routes-option-adapter": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "autosize": "6.0.1",
    "date-fns": "4.1.0",
    "dotenv": "^17.4.2",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "8.2.1",
    "isbot": "^5.1.39",
    "ky": "^2.0.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.5",
    "nanoid": "^5.1.9",
    "query-string": "9.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router": "^7.14.1",
    "react-router-dom": "^7.14.1",
    "remix-i18next": "^7.5.0",
    "remix-toast": "4.0.0",
    "remix-utils": "9.3.1",
    "sonner": "2.0.7",
    "spark-md5": "3.0.2",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/js": "9.39.2",
    "@faker-js/faker": "10.4.0",
    "@mswjs/data": "0.16.2",
    "@playwright-testing-library/test": "4.5.0",
    "@playwright/test": "1.59.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/fs-routes": "^7.14.1",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/accept-language-parser": "1.5.8",
    "@types/autosize": "4.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/spark-md5": "3.0.5",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vueless/storybook-dark-mode": "10.0.7",
    "accept-language-parser": "1.5.0",
    "chromatic": "^16.3.0",
    "eslint": "9.39.2",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-canonical": "5.1.3",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jest-formatting": "3.1.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-no-switch-statements": "1.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "2.10.2",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "10.3.5",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-typescript-enum": "2.1.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-you-dont-need-lodash-underscore": "6.14.0",
    "happy-dom": "^20.9.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lint-staged": "16.4.0",
    "msw": "^2.13.4",
    "msw-storybook-addon": "2.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "remix-flat-routes": "0.8.5",
    "storybook": "10.3.5",
    "storybook-react-i18next": "10.1.2",
    "stylelint": "^17.8.0",
    "stylelint-config-clean-order": "8.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-tailwindcss": "1.0.1",
    "stylelint-order": "8.1.1",
    "tailwindcss": "4.2.2",
    "typescript": "^6.0.3",
    "vite": "8.0.9",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "remix-i18next": {
      "i18next": "$i18next",
      "react-i18next": "$react-i18next"
    },
    "vite-node": "^6.0.0"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
